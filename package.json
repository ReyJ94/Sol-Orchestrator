{
  "name": "opencode-sol-orchestrator",
  "version": "0.2.0-beta",
  "description": "Graph-native multi-agent orchestration for OpenCode with durable goals, workflow DAGs, active supervision, and profile-based delegation.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ReyJ94/Sol-Orchestrator.git"
  },
  "homepage": "https://github.com/ReyJ94/Sol-Orchestrator#readme",
  "bugs": {
    "url": "https://github.com/ReyJ94/Sol-Orchestrator/issues"
  },
  "license": "MIT",
  "author": "reyj94",
  "type": "module",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./compaction-snapshot": {
      "types": "./dist/compaction-snapshot.d.ts",
      "import": "./dist/compaction-snapshot.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    }
  },
  "files": [
    "dist",
    "agents",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "turbo run lint:local",
    "lint:local": "ultracite check .",
    "lint:fix": "ultracite fix .",
    "format": "ultracite fix .",
    "format:check": "ultracite check .",
    "typecheck": "turbo run typecheck:local",
    "typecheck:local": "tsc --project tsconfig.json --noEmit",
    "test": "turbo run test:local",
    "test:local": "bun test",
    "test:watch": "bun test --watch",
    "check": "turbo run lint:local typecheck:local test:local",
    "build": "turbo run build:local",
    "build:local": "bun run scripts/build.ts && tsc --project tsconfig.build.json",
    "pack:dry-run": "bun pm pack --dry-run",
    "prepack": "bun run build:local"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.18.2",
    "@opentui/solid": "0.4.3",
    "solid-js": "1.9.12",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "1.3.14",
    "@types/node": "24.13.2",
    "turbo": "2.9.16",
    "typescript": "6.0.3",
    "ultracite": "7.8.1"
  },
  "engines": {
    "bun": ">=1.3.14",
    "opencode": ">=1.18.1"
  },
  "packageManager": "bun@1.3.14",
  "publishConfig": {
    "access": "public"
  }
}
