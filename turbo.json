{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build:local": {
      "dependsOn": ["typecheck:local"],
      "outputs": ["dist/**"]
    },
    "lint:local": {
      "outputs": []
    },
    "test:local": {
      "dependsOn": ["typecheck:local"],
      "outputs": []
    },
    "typecheck:local": {
      "outputs": []
    }
  }
}
